# Copie este arquivo para .env e ajuste os valores locais.

# Banco de dados
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/valora
SPRING_DATASOURCE_USERNAME=valora
SPRING_DATASOURCE_PASSWORD=valora

# Redis
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=

# JWT
JWT_SECRET=troque-esta-chave-por-um-valor-forte

# BRAPI
BRAPI_TOKEN=seu-token-aqui

